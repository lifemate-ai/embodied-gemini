# Garmin Connect companion biometrics
GARMIN_EMAIL="you@example.com"
GARMIN_PASSWORD="your-password"
# Optional: reuse Garmin OAuth tokens here instead of the default ~/.garminconnect
GARMINTOKENS="~/.garminconnect"
# Leave this off unless you explicitly want to try the legacy first-login path.
# As of 2026-03-28, garth reports Garmin auth changes that may break new logins.
GEMINI_GARMIN_ALLOW_LEGACY_PASSWORD_LOGIN="0"

# Optional continuity companion biometrics overrides
GEMINI_COMPANION_BIOMETRICS_PATH="/tmp/companion_biometrics.json"
GEMINI_GARMIN_SLEEP_LOOKBACK_DAYS="2"
GEMINI_GARMIN_BODY_BATTERY_LOOKBACK_DAYS="2"
# Optional LAN ingest server for external companion biometrics senders
GEMINI_COMPANION_BIOMETRICS_INGEST_BIND="0.0.0.0"
GEMINI_COMPANION_BIOMETRICS_INGEST_PORT="8765"
GEMINI_COMPANION_BIOMETRICS_INGEST_TOKEN=""
# Optional: override the source label written by the LAN ingest receiver.
# Leave unset to use the script default.
# GEMINI_COMPANION_BIOMETRICS_SOURCE="external-companion"
# Keep this off by default so the continuity hook does not spam Garmin SSO
# before a token cache exists.
GEMINI_GARMIN_ALLOW_PASSWORD_LOGIN_IN_HOOK="0"
