{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$GEMINI_PROJECT_DIR\"/.gemini/hooks/post-compact-recovery.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeModel": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$GEMINI_PROJECT_DIR\"/.gemini/hooks/interoception.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$GEMINI_PROJECT_DIR\"/.gemini/hooks/continue-check.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "usb-webcam": {
      "command": "uv",
      "args": ["run", "--directory", "usb-webcam-mcp", "usb-webcam-mcp"]
    },
    "wifi-cam": {
      "command": "uv",
      "args": ["run", "--directory", "wifi-cam-mcp", "wifi-cam-mcp"],
      "env": {
        "TAPO_CAMERA_HOST": "192.168.1.xxx",
        "TAPO_USERNAME": "admin",
        "TAPO_PASSWORD": "your_tapo_password",
        "TAPO_STREAM_URL": "rtsp://admin:your_tapo_password@192.168.1.xxx:554/cam/realmonitor?channel=1&subtype=0",
        "TAPO_ONVIF_PORT": "80",
        "TAPO_PTZ_MODE": "continuous"
      }
    },
    "mobility": {
      "command": "uv",
      "args": ["run", "--directory", "mobility-mcp", "mobility-mcp"],
      "env": {
        "TUYA_DEVICE_ID": "your_tuya_device_id",
        "TUYA_API_KEY": "your_tuya_api_key",
        "TUYA_API_SECRET": "your_tuya_api_secret",
        "TUYA_API_REGION": "us"
      }
    },
    "desire-system": {
      "command": "uv",
      "args": ["run", "--directory", "desire-system", "desire-system"]
    },
    "memory": {
      "command": "uv",
      "args": ["run", "--directory", "memory-mcp", "memory-mcp"]
    },
    "system-temperature": {
      "command": "uv",
      "args": ["run", "--directory", "system-temperature-mcp", "system-temperature-mcp"]
    },
    "tts": {
      "command": "uv",
      "args": ["run", "--directory", "tts-mcp", "tts-mcp"],
      "env": {
        "ELEVENLABS_API_KEY": "sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "ELEVENLABS_VOICE_ID": "your_voice_id",
        "ELEVENLABS_MODEL_ID": "eleven_v3",
        "ELEVENLABS_OUTPUT_FORMAT": "mp3_44100_128",
        "ELEVENLABS_PLAY_AUDIO": "true",
        "ELEVENLABS_SAVE_DIR": "/tmp/elevenlabs-t2s",
        "ELEVENLABS_PLAYBACK": "paplay",
        "ELEVENLABS_PULSE_SINK": "1",
        "ELEVENLABS_PULSE_SERVER": "unix:/mnt/wslg/PulseServer",
        "TTS_PLAYBACK": "auto",
        "GO2RTC_URL": "http://localhost:1984",
        "GO2RTC_STREAM": "tapo_cam"
      }
    },
    "x-mcp": {
      "command": "uv",
      "args": ["run", "--directory", "x-mcp", "x-mcp"],
      "env": {
        "XAI_API_KEY": "xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "X_CONSUMER_KEY": "your_x_consumer_key",
        "X_CONSUMER_SECRET": "your_x_consumer_secret",
        "X_ACCESS_TOKEN": "your_x_access_token",
        "X_ACCESS_TOKEN_SECRET": "your_x_access_token_secret"
      }
    }
  }
}
